rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function adminPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function userRole() {
      return isSignedIn() && exists(userPath()) ? get(userPath()).data.rol : null;
    }

    function userEmpresaId() {
      return isSignedIn() && exists(userPath())
        ? get(userPath()).data.empresaId
        : null;
    }

    function userSedeId() {
      return isSignedIn() && exists(userPath())
        ? get(userPath()).data.sedeId
        : null;
    }

    function userScope() {
      return isSignedIn()
        && exists(userPath())
        && get(userPath()).data.scope is list
        ? get(userPath()).data.scope
        : [];
    }

    function isGlobalReader() {
      return isGerencia()
        || (
          isSignedIn()
          && exists(userPath())
          && get(userPath()).data.isGlobalRead == true
        );
    }

    function hasRole(role) {
      return userRole() == role;
    }

    function isVisitador() {
      return hasRole("VISITADOR");
    }

    function isAuxiliar() {
      return hasRole("AUXILIAR_ADMINISTRATIVA");
    }

    function isBiomedico() {
      return hasRole("INGENIERO_BIOMEDICO");
    }

    function isGerencia() {
      return hasRole("GERENCIA");
    }

    function hasValidRole() {
      return isVisitador() || isAuxiliar() || isBiomedico() || isGerencia();
    }

    function isAdmin() {
      return isSignedIn()
        && exists(adminPath())
        && get(adminPath()).data.enabled == true;
    }

    function hasAccessRole() {
      return hasValidRole() || isAdmin();
    }

    function hasOrgContext(data) {
      return data.empresaId is string && data.sedeId is string;
    }

    function isSameUserOrg(data) {
      return hasOrgContext(data)
        && (
          (
            userEmpresaId() is string
            && userSedeId() is string
            && data.empresaId == userEmpresaId()
            && data.sedeId == userSedeId()
          )
          || ({empresaId: data.empresaId, sedeId: data.sedeId} in userScope())
        );
    }

    function canReadOrgDoc(data) {
      return isSignedIn()
        && hasAccessRole()
        && (
          isAdmin()
          || isGlobalReader()
          || isBiomedico()
          || isSameUserOrg(data)
        );
    }

    function canCreateInOwnOrg() {
      return isSignedIn()
        && (
          (isBiomedico() && hasOrgContext(request.resource.data))
          || isSameUserOrg(request.resource.data)
        );
    }

    function canUpdateInOwnOrg() {
      return (
        isBiomedico()
        && hasOrgContext(request.resource.data)
      ) || (
        isSameUserOrg(resource.data)
        && isSameUserOrg(request.resource.data)
      );
    }

    function canDeleteInOwnOrg() {
      return (isBiomedico() && hasOrgContext(resource.data))
        || isSameUserOrg(resource.data);
    }

    function equipoPathById(equipoId) {
      return /databases/$(database)/documents/equipos/$(equipoId);
    }

    function equipoExists(equipoId) {
      return equipoId is string && exists(equipoPathById(equipoId));
    }

    function tipoActivoEsBiomedico(data) {
      return !(data.tipoActivo is string) || data.tipoActivo == "BIOMEDICO";
    }

    function linkedEquipoEsBiomedico(equipoId) {
      return equipoExists(equipoId)
        && tipoActivoEsBiomedico(get(equipoPathById(equipoId)).data);
    }

    function hasConsultorioId(data) {
      return data.consultorioId is string && data.consultorioId != "";
    }

    function consultorioTransitionAllowed() {
      // No cambia consultorio: permitido.
      return request.resource.data.consultorioId == resource.data.consultorioId
        // Quitar consultorio siempre permitido.
        || !hasConsultorioId(request.resource.data)
        // Asignar por primera vez (no mover directo entre consultorios).
        || (
          !hasConsultorioId(resource.data)
          && hasConsultorioId(request.resource.data)
          && resource.data.estado != "DADO_DE_BAJA"
          && request.resource.data.estado != "DADO_DE_BAJA"
        );
    }

    function consultorioCreateAllowed() {
      return !hasConsultorioId(request.resource.data)
        || request.resource.data.estado != "DADO_DE_BAJA";
    }

    function canDeleteEquipoDoc() {
      return !hasConsultorioId(resource.data);
    }

    // --- USERS ---
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // --- ADMINS (flag para habilitar pantalla Admin) ---
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // --- CATALOGO ORGANIZACIONAL ---
    match /empresas/{id} {
      allow read: if isSignedIn() && hasAccessRole();
      allow create, update, delete: if false;
    }

    match /sedes/{id} {
      allow read: if isSignedIn() && hasAccessRole();
      allow create, update, delete: if false;
    }

    // --- CONSULTORIOS (Aliados / consulta externa) ---
    match /consultorios/{id} {
      allow read: if canReadOrgDoc(resource.data)
        && (isBiomedico() || isAuxiliar() || isGerencia() || isAdmin());
      allow create: if isBiomedico() && canCreateInOwnOrg();
      allow update: if isBiomedico() && canUpdateInOwnOrg();
      allow delete: if isBiomedico() && canDeleteInOwnOrg();
    }

    // --- PACIENTES ---
    match /pacientes/{id} {
      // VISITADOR: puede ver pacientes activos (para rutero)
      allow read: if canReadOrgDoc(resource.data)
        && (!isVisitador() || resource.data.estado == "ACTIVO");

      allow create: if isAuxiliar() && canCreateInOwnOrg();
      allow delete: if isAuxiliar() && canDeleteInOwnOrg();
      allow update: if (
        isAuxiliar() && canUpdateInOwnOrg()
      ) || (
        isVisitador()
        && canUpdateInOwnOrg()
        && resource.data.estado == "ACTIVO"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "zona",
          "direccion",
          "telefono",
          "barrio"
        ])
        && (
          !(request.resource.data.zona is string)
          || request.resource.data.zona in [
            "GIRON",
            "BGA1",
            "BGA2",
            "PIEDECUESTA",
            "FLORIDABLANCA"
          ]
        )
      );
    }

    // --- PROFESIONALES ---
    match /profesionales/{id} {
      allow read: if canReadOrgDoc(resource.data)
        && (isAuxiliar() || isGerencia() || isBiomedico());
      allow create: if isAuxiliar() && canCreateInOwnOrg();
      allow update: if isAuxiliar() && canUpdateInOwnOrg();
      allow delete: if isAuxiliar() && canDeleteInOwnOrg();
    }

    // --- EQUIPOS ---
    match /equipos/{id} {
      // VISITADOR: solo puede ver equipos con asignación activa
      allow read: if canReadOrgDoc(resource.data)
        && (!isVisitador() || resource.data.asignadoActivo == true);
      allow create: if isBiomedico() && consultorioCreateAllowed();
      allow update: if isBiomedico() && consultorioTransitionAllowed();
      allow delete: if isBiomedico() && canDeleteEquipoDoc();

      // --- CALIBRACIONES (subcolección) ---
      match /calibraciones/{calId} {
        function parentEquipoData() {
          return get(/databases/$(database)/documents/equipos/$(id)).data;
        }

        function parentEquipoEsBiomedico() {
          return tipoActivoEsBiomedico(parentEquipoData());
        }

        function canReadCalibracionDoc() {
          return canReadOrgDoc(resource.data) || canReadOrgDoc(parentEquipoData());
        }

        allow read: if canReadCalibracionDoc()
          && (isBiomedico() || isAuxiliar() || isGerencia() || isAdmin());
        allow create: if isBiomedico()
          && canCreateInOwnOrg()
          && isSameUserOrg(parentEquipoData())
          && parentEquipoEsBiomedico();
        allow update: if isBiomedico()
          && (
            canUpdateInOwnOrg()
            || isSameUserOrg(parentEquipoData())
          )
          && parentEquipoEsBiomedico()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "certificado",
            "costo",
            "observaciones",
            "updatedAt"
          ]);
        allow delete: if false;
      }
    }

    // --- ASIGNACIONES ---
    match /asignaciones/{id} {
      // VISITADOR: solo puede ver asignaciones activas
      allow read: if canReadOrgDoc(resource.data)
        && (!isVisitador() || resource.data.estado == "ACTIVA");

      allow create: if isAuxiliar() && canCreateInOwnOrg();

      // actualizar: auxiliar completo, visitador solo para capturar firma.
      allow update: if (
        isAuxiliar() && canUpdateInOwnOrg()
      ) || (
        isVisitador()
        && canUpdateInOwnOrg()
        && resource.data.estado == "ACTIVA"
        && (resource.data.firmaPacienteEntrega == null
          || resource.data.firmaPacienteEntrega == "")
        && request.resource.data.firmaPacienteEntrega is string
        && request.resource.data.firmaPacienteEntregaCapturadaAt is string
        && request.resource.data.firmaPacienteEntregaCapturadaPorUid == request.auth.uid
        && request.resource.data.firmaPacienteEntregaCapturadaPorNombre is string
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "firmaPacienteEntrega",
          "firmaPacienteEntregaCapturadaAt",
          "firmaPacienteEntregaCapturadaPorUid",
          "firmaPacienteEntregaCapturadaPorNombre"
        ])
      );
      allow delete: if false;
    }

    // --- ASIGNACIONES PROFESIONALES ---
    match /asignaciones_profesionales/{id} {
      allow read: if canReadOrgDoc(resource.data)
        && (isAuxiliar() || isGerencia() || isBiomedico());
      allow create: if isAuxiliar() && canCreateInOwnOrg();
      allow update: if isAuxiliar() && canUpdateInOwnOrg();
      allow delete: if false;
    }

    // --- ACTAS PROFESIONALES (entrega multiple) ---
    match /actas_profesionales/{id} {
      allow read: if canReadOrgDoc(resource.data)
        && (isAuxiliar() || isGerencia() || isBiomedico() || isAdmin());
      allow create: if isAuxiliar() && canCreateInOwnOrg();
      allow update: if isAuxiliar() && canUpdateInOwnOrg();
      allow delete: if false;
    }

    // --- ACTAS INTERNAS (biomedico -> auxiliar) ---
    match /actas_internas/{id} {
      allow read: if canReadOrgDoc(resource.data)
        && (isAuxiliar() || isGerencia() || isBiomedico() || isAdmin());
      allow create, update, delete: if false;
    }

    // --- TIPOS DE EQUIPO (plantillas de hoja de vida) ---
    match /tipos_equipo/{id} {
      allow read: if isSignedIn() && hasAccessRole();
      allow create, update, delete: if isSignedIn() && isBiomedico();
    }

    // --- REPORTES (VISITADOR -> BIOMEDICO) ---
    match /reportes_equipos/{id} {
      // Creación solo por Cloud Function (Admin SDK).
      allow create: if false;

      // Lectura: biomédico/gerencia pueden ver todo; visitador solo lo suyo
      allow read: if canReadOrgDoc(resource.data) && (
        isBiomedico()
        || isGerencia()
        || (isVisitador() && resource.data.creadoPorUid == request.auth.uid)
      );

      allow update: if canUpdateInOwnOrg() && (
        (
          isBiomedico()
          && resource.data.estado == "ABIERTO"
          && request.resource.data.estado == "EN_PROCESO"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "estado",
            "diagnostico",
            "planReparacion",
            "enProcesoAt",
            "enProcesoPorUid",
            "enProcesoPorNombre",
            "historial"
          ])
        )
        || (
          isBiomedico()
          && resource.data.estado == "EN_PROCESO"
          && request.resource.data.estado == "EN_PROCESO"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "diagnostico",
            "planReparacion",
            "historial"
          ])
        )
        || (
          isBiomedico()
          && resource.data.estado == "EN_PROCESO"
          && request.resource.data.estado == "CERRADO"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "estado",
            "cerradoAt",
            "cerradoPorUid",
            "cerradoPorNombre",
            "cierreNotas",
            "historial"
          ])
        )
        || (
          isVisitador()
          && resource.data.estado == "CERRADO"
          && request.resource.data.estado == "CERRADO"
          && resource.data.creadoPorUid == request.auth.uid
          && request.resource.data.creadoPorUid == resource.data.creadoPorUid
          && resource.data.vistoPorVisitadorAt == null
          && request.resource.data.vistoPorVisitadorAt is string
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "vistoPorVisitadorAt"
          ])
        )
      );

      allow delete: if false;
    }

    // --- SOLICITUDES EQUIPOS PACIENTE (VISITADOR -> BIOMEDICO) ---
    match /solicitudes_equipos_paciente/{id} {
      allow create: if isVisitador()
        && canCreateInOwnOrg()
        && request.resource.data.estado == "PENDIENTE"
        && request.resource.data.creadoPorUid == request.auth.uid
        && request.resource.data.creadoPorNombre is string
        && request.resource.data.idPaciente is string
        && request.resource.data.pacienteNombre is string
        && request.resource.data.pacienteDocumento is string
        && request.resource.data.tipoPropiedad in [
          "PACIENTE",
          "ALQUILADO",
          "MEDICUC"
        ]
        && request.resource.data.equipoNombre is string
        && (
          request.resource.data.tipoPropiedad != "ALQUILADO"
          || request.resource.data.empresaAlquiler is string
        )
        && request.resource.data.fotos.size() >= 3
        && request.resource.data.fotos.size() <= 5;

      allow read: if canReadOrgDoc(resource.data) && (
        isBiomedico()
        || isGerencia()
        || (isVisitador() && resource.data.creadoPorUid == request.auth.uid)
      );

      allow update: if isBiomedico()
        && canUpdateInOwnOrg()
        && resource.data.estado == "PENDIENTE"
        && request.resource.data.estado == "APROBADA"
        && request.resource.data.aprobadoPorUid == request.auth.uid
        && request.resource.data.aprobadoPorNombre is string
        && request.resource.data.aprobadoAt is string
        && request.resource.data.equipoId is string
        && request.resource.data.creadoPorUid == resource.data.creadoPorUid
        && request.resource.data.idPaciente == resource.data.idPaciente
        && request.resource.data.tipoPropiedad == resource.data.tipoPropiedad
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "estado",
          "aprobadoAt",
          "aprobadoPorUid",
          "aprobadoPorNombre",
          "equipoId",
          "asignacionId",
          "actaInternaId",
          "actaInternaEstado",
          "updatedAt"
        ]);

      allow delete: if false;
    }

    // --- MANTENIMIENTOS (BIOMEDICO -> AUXILIAR) ---
    match /mantenimientos/{id} {
      allow read: if canReadOrgDoc(resource.data)
        && (isBiomedico() || isAuxiliar() || isGerencia());
      allow create: if (isBiomedico() || isAuxiliar())
        && canCreateInOwnOrg()
        && linkedEquipoEsBiomedico(request.resource.data.equipoId);
      allow update: if (isBiomedico() || isAuxiliar())
        && canUpdateInOwnOrg()
        && request.resource.data.equipoId == resource.data.equipoId
        && linkedEquipoEsBiomedico(resource.data.equipoId);
      allow delete: if false;
    }

    // --- DENY DEFAULT ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
