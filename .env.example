# Copia este archivo a `.env.local` y reemplaza los valores.
# En Vite, las variables del frontend deben iniciar con `VITE_`.
# No registrar credenciales reales en el repositorio.

# Firebase Web App
VITE_FIREBASE_API_KEY=REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_ME
VITE_FIREBASE_PROJECT_ID=REPLACE_ME
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_ME
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
VITE_FIREBASE_APP_ID=REPLACE_ME

# Opcional: Analytics en producción
VITE_FIREBASE_MEASUREMENT_ID=REPLACE_ME

# Pendiente por confirmar:
# `vite.config.ts` referencia GEMINI_API_KEY, pero no se identificó uso funcional
# directo en los módulos principales revisados.
# GEMINI_API_KEY=REPLACE_ME
